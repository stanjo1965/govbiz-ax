# ============================================
# GovBiz AX 모노레포 환경 변수 예시
# 이 파일을 복사하여 .env.local 로 사용하세요
# cp .env.example .env.local
# ============================================

# Claude AI API Key (필수)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Next-Auth 시크릿 (필수)
# openssl rand -base64 32 로 생성
AUTH_SECRET=your-nextauth-secret-here

# ============================================
# 01. 농축산물 알뜰 소비 플랫폼 (포트 3001)
# ============================================
# 농식품 공공데이터 API (https://www.data.go.kr)
AGRI_DATA_API_KEY=

# 네이버 지도 API
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# 가격 DB (PostgreSQL + TimescaleDB)
AGRI_DATABASE_URL=postgresql://user:password@localhost:5432/agri_price

# ============================================
# 02. 소상공인 창업·경영 컨설팅 (포트 3002)
# ============================================
# 소상공인진흥공단 API
BIZ_DATA_API_KEY=

# 상권분석 데이터 DB (PostgreSQL + PostGIS)
BIZ_DATABASE_URL=postgresql://user:password@localhost:5432/biz_consulting

# ============================================
# 03. 국가유산 AI 해설 (포트 3003)
# ============================================
# 국가유산청 Open API
HERITAGE_API_KEY=

# 국가유산 DB (PostgreSQL + pgvector)
HERITAGE_DATABASE_URL=postgresql://user:password@localhost:5432/heritage_guide

# ============================================
# 04. 해상안전 Deep Blue Eye (포트 3004)
# ============================================
# 해양경찰청 AIS 데이터 API
MARITIME_API_KEY=

# 해상안전 DB (PostgreSQL + PostGIS + TimescaleDB)
MARITIME_DATABASE_URL=postgresql://user:password@localhost:5432/deep_blue_eye

# ============================================
# 05. 식의약품 안전 지킴이 (포트 3005)
# ============================================
# 식품의약품안전처 API
SAFETY_DATA_API_KEY=

# 안전정보 DB (PostgreSQL + Elasticsearch)
SAFETY_DATABASE_URL=postgresql://user:password@localhost:5432/safety_guardian
ELASTICSEARCH_URL=http://localhost:9200

# ============================================
# 06. AI 국세상담 (포트 3006)
# ============================================
# 국세청 Open API
TAX_API_KEY=

# 세무 DB (PostgreSQL + Neo4j)
TAX_DATABASE_URL=postgresql://user:password@localhost:5432/tax_counsel
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============================================
# 07. 모두의 경찰관 (포트 3007)
# ============================================
# 경찰청 Open API
POLICE_API_KEY=

# 경찰민원 DB
POLICE_DATABASE_URL=postgresql://user:password@localhost:5432/police_for_all

# ============================================
# 08. 통합인허가 사전진단 (포트 3008)
# ============================================
# 국토교통부 토지이음 API
LAND_API_KEY=

# 인허가 DB (PostgreSQL + PostGIS)
PERMIT_DATABASE_URL=postgresql://user:password@localhost:5432/permit_diagnosis
